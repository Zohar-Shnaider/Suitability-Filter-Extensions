#!/bin/bash
#SBATCH -A nic
#SBATCH -q nic
#SBATCH -p nic
#SBATCH --gres=gpu:1
#SBATCH -c 4
#SBATCH --mem=40GB
#SBATCH --output=./out_err_slurm/%j.out
#SBATCH --error=./out_err_slurm/%j.err
python wilds/examples/run_expt.py --dataset civilcomments --seed 0 --algorithm IRM --root_dir /path/to/wilds/data/ --log_dir /path/to/experiment/logs/IRM/civilcomments --use_wandb --wandb_api_key_path /path/to/wandb_key.txt --wandb_kwargs project=WILDS name=civilcomments 
